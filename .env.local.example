# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit secrets.

# Supabase — get these from https://app.supabase.com/project/_/settings/api
#
# Expo Router reads EXPO_PUBLIC_* at build time (web + native).
# NEXT_PUBLIC_* are kept for now so the legacy Next app still boots on `main`;
# they'll be removed in Phase 11 when Next is deleted.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only — used inside app/api/**+api.ts (Expo) or src/app/api (Next).
# Never bundled into client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic — get from https://console.anthropic.com/account/keys
# Used by /api/parse-trip to convert natural-language trip descriptions to form fields.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# SerpAPI — get from https://serpapi.com/manage-api-key
# Used for Google Hotels + Vacation Rentals searches.
SERPAPI_KEY=YOUR_SERPAPI_KEY

# Google Places API — for trip-location autocomplete.
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_KEY

# Apify — optional, used by some listing providers.
APIFY_TOKEN=YOUR_APIFY_TOKEN

