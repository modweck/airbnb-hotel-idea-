# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit secrets.

# Supabase — get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only Supabase service role key (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic — get from https://console.anthropic.com/account/keys
# Used by /api/parse-trip to convert natural-language trip descriptions to form fields.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# Apify — get from https://console.apify.com/account/integrations
APIFY_TOKEN=YOUR_APIFY_TOKEN

# Apify actor IDs (fill these once you've picked / built actors)
APIFY_VRBO_ACTOR_ID=
APIFY_BOOKING_ACTOR_ID=
